# ─── Google Apps Script Web App ───────────────────────────────────────────────
#
# URL опублікованого Web App (Deploy as Web App → Execute as Me → Anyone).
# Використовується для:
#   GET  ?action=getAvailability&checkIn=YYYY-MM-DD&checkOut=YYYY-MM-DD
#   POST JSON { action: "createBooking", checkIn, checkOut, roomId, guestName, email, phone?, note? }
#
# Без цієї змінної сайт працює у demo-режимі:
#   — наявність кімнат показується згенерованими mock-даними
#   — бронювання підтверджується з референсом DEMO-<timestamp>
#
SHEETS_WEBAPP_BASE_URL=https://script.google.com/macros/s/XXXX/exec
